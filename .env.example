DATABASE_URL=postgres://postgres:operon_dev@localhost:5432/operon
OPERON_API_BIND=127.0.0.1:8080
OPERON_JWT_SECRET=replace-with-at-least-32-random-bytes
OPERON_INTERNAL_SECRET=replace-with-same-value-in-next-env
OPERON_WEB_ORIGIN=http://localhost:3000
OPERON_OAUTH_REDIRECT_BASE=http://127.0.0.1:8080
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
OPERON_AGENT_MODEL=gpt-4o-mini
OPERON_AGENT_MAX_STEPS=200
OPERON_WORKSPACE_ROOT=./workspaces
OPENAI_API_KEY=replace-with-openai-key
RUST_LOG=operonx=debug,tower_http=info,sqlx=warn
